# =============================================================================
# PrepIQ — Root Environment Template
# =============================================================================
# This file documents every environment variable used across the project.
# Copy to .env and fill in real values before running anything.
#
#   cp .env.example .env
#
# NEVER commit .env — it is already in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE  (required)
# -----------------------------------------------------------------------------
# Supabase Transaction Pooler URL — use port 6543 for the application.
# The app strips ?pgbouncer=true automatically, so you can leave it in.
#
# Find it: Supabase Dashboard → Project Settings → Database
#          → Connection string → Transaction pooler
#
DATABASE_URL=postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true


# -----------------------------------------------------------------------------
# SUPABASE  (required)
# -----------------------------------------------------------------------------
# Find both keys: Supabase Dashboard → Project Settings → API

# Project URL
SUPABASE_URL=https://YOURPROJECT.supabase.co

# Service Role key — backend only, never expose to the browser
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# Anon / public key — safe for the frontend
SUPABASE_ANON_KEY=eyJ...your-anon-key...


# -----------------------------------------------------------------------------
# SECURITY  (required)
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
JWT_SECRET=replace-with-a-random-32-char-minimum-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440


# -----------------------------------------------------------------------------
# CORS  (required)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# In development the backend allows all origins automatically.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Your deployed frontend URL — used to restrict CORS in production
FRONTEND_URL=https://your-app.vercel.app


# -----------------------------------------------------------------------------
# AI / ML  (required for AI features)
# -----------------------------------------------------------------------------
# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...your-gemini-key...

# Bytez — https://bytez.com (used for external ML model calls)
BYTEZ_API_KEY=your-bytez-api-key


# -----------------------------------------------------------------------------
# APPLICATION  (optional — defaults shown)
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server bind (used when running main.py directly)
HOST=0.0.0.0
PORT=8000


# Keep-alive ping URL — the backend pings this every 14 min to prevent
# Render free-tier spin-down. Set to your deployed Render service URL.
# Only active when ENVIRONMENT=production.
HEALTH_ENDPOINT=https://your-service.onrender.com/health

# -----------------------------------------------------------------------------
# FILE UPLOADS  (optional — defaults shown)
# -----------------------------------------------------------------------------
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE=10485760

# Enable heavy ML pipeline (EasyOCR, YOLOv8, Transformers).
# Requires significant RAM — leave false on free-tier deployments.
ENABLE_HEAVY_ML=false


# -----------------------------------------------------------------------------
# REDIS  (optional — only needed if you add caching)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# EMAIL / SMTP  (optional — only needed for email notifications)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password


# -----------------------------------------------------------------------------
# FRONTEND  (reference — these go in frontend/.env.local, not here)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_MODE=real
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
