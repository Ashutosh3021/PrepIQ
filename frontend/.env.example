# =============================================================================
# PrepIQ Frontend — Environment Template
# =============================================================================
# Copy to frontend/.env.local and fill in real values.
#
#   cp frontend/.env.example frontend/.env.local
#
# NEVER commit frontend/.env.local — it is already in .gitignore.
# Variables prefixed NEXT_PUBLIC_ are embedded in the browser bundle.
# Do NOT put secrets (service role keys, JWT secrets) here.
# =============================================================================


# -----------------------------------------------------------------------------
# API MODE  (required)
# -----------------------------------------------------------------------------
# mock  → all API calls return hardcoded data; no backend needed
# real  → calls the live FastAPI backend at NEXT_PUBLIC_API_URL
NEXT_PUBLIC_API_MODE=real


# -----------------------------------------------------------------------------
# BACKEND URL  (required when API_MODE=real)
# -----------------------------------------------------------------------------
# Local development
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Production example (uncomment and set your Render URL)
# NEXT_PUBLIC_API_URL=https://prepiq-backend.onrender.com/api/v1


# -----------------------------------------------------------------------------
# SUPABASE  (required — OAuth auth)
# -----------------------------------------------------------------------------
# Find both values: Supabase Dashboard → Project Settings → API

# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co

# Anon / public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...


# -----------------------------------------------------------------------------
# FEATURE FLAGS  (optional — defaults shown)
# -----------------------------------------------------------------------------
# Set to false to hide a feature in the UI without removing code.
NEXT_PUBLIC_ENABLE_AI_TUTOR=true
NEXT_PUBLIC_ENABLE_PREDICTIONS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
