# =============================================
# PREPIQ FRONTEND ENVIRONMENT CONFIGURATION
# =============================================
#
# Copy this file to .env.local (for dev) or set in Vercel (for prod)
# Variables prefixed with NEXT_PUBLIC_ are available in the browser

# =============================================
# API CONFIGURATION
# =============================================
# Development: http://localhost:8000
# Production: https://your-backend-name.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================
# SUPABASE CONFIGURATION
# =============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================
# APP SETTINGS
# =============================================
NEXT_PUBLIC_APP_NAME=PrepIQ
NEXT_PUBLIC_APP_DESCRIPTION=AI-Powered Exam Preparation Platform

# =============================================
# FEATURE FLAGS (Optional)
# =============================================
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
