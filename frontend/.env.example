# API Mode: "mock" for local development, "real" for production
NEXT_PUBLIC_API_MODE=mock

# Real backend base URL (ML/AI backend)
NEXT_PUBLIC_API_BASE_URL=https://api.prepiq.yourdomain.com

# Auth (placeholder — leave empty until auth phase)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=placeholder-change-in-production

# Feature flags
NEXT_PUBLIC_ENABLE_AI_TUTOR=true
NEXT_PUBLIC_ENABLE_PREDICTIONS=true
