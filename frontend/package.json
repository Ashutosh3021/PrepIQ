{
  "name": "prepiq-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "check-nav": "npx tsx scripts/check-nav-consistency.ts",
    "verify-pages": "npx tsx scripts/verify-pages.ts",
    "audit-hrefs": "npx tsx scripts/audit-hrefs.ts",
    "check-console": "npx tsx scripts/check-console-errors.ts",
    "check-types": "npx tsc --noEmit",
    "check-css-vars": "npx tsx scripts/check-css-variables.ts"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "next": "14.2.35",
    "next-auth": "4.24.13",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "swr": "2.4.0",
    "tailwind-merge": "2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "22.13.5",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "^10.4.27",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "1.50.1",
    "postcss": "8.5.3",
    "prettier": "3.5.2",
    "tailwindcss": "3.4.17",
    "ts-jest": "^29.4.9",
    "typescript": "5.7.3"
  }
}
