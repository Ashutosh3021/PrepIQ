# =============================================================================
# PrepIQ Backend — Environment Template
# =============================================================================
# Copy to backend/.env and fill in real values.
#
#   cp backend/.env.example backend/.env
#
# NEVER commit backend/.env — it is already in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE  (required)
# -----------------------------------------------------------------------------
# Supabase Transaction Pooler — port 6543.
# The app strips ?pgbouncer=true automatically.
#
# Find it: Supabase Dashboard → Project Settings → Database
#          → Connection string → Transaction pooler
#
DATABASE_URL=postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true


# -----------------------------------------------------------------------------
# SUPABASE  (required)
# -----------------------------------------------------------------------------
# Find both keys: Supabase Dashboard → Project Settings → API

# Project URL
SUPABASE_URL=https://YOURPROJECT.supabase.co

# Service Role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# Anon key — kept here for reference; the frontend reads its own copy
SUPABASE_ANON_KEY=eyJ...your-anon-key...


# -----------------------------------------------------------------------------
# SECURITY  (required)
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
# In production the app will refuse to start if this is missing or set to the
# default placeholder value.
JWT_SECRET=replace-with-a-random-32-char-minimum-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440


# -----------------------------------------------------------------------------
# CORS  (required)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# In development mode (ENVIRONMENT=development) the backend allows all origins
# automatically, so this only matters in staging / production.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# -----------------------------------------------------------------------------
# AI / ML  (required for AI features)
# -----------------------------------------------------------------------------
# Google Gemini — https://aistudio.google.com/app/apikey
# Used by: prediction engine, AI tutor chat, concept explainer
GEMINI_API_KEY=AIza...your-gemini-key...

# Bytez — https://bytez.com
# Used by: external ML model calls (summarisation, QA, text generation)
BYTEZ_API_KEY=your-bytez-api-key


# -----------------------------------------------------------------------------
# APPLICATION  (optional — defaults shown)
# -----------------------------------------------------------------------------
# development | staging | production
# In production the app performs hard validation of all required vars.
ENVIRONMENT=development

# Set true to expose /docs, /redoc, /openapi.json
DEBUG=true

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Server bind — used when running `python app/main.py` directly
HOST=0.0.0.0
PORT=8000


# -----------------------------------------------------------------------------
# FILE UPLOADS  (optional — defaults shown)
# -----------------------------------------------------------------------------
# Temporary directory for files before they are uploaded to Supabase Storage
UPLOAD_FOLDER=./uploads

# Maximum upload size in bytes (default 10 MB)
MAX_FILE_SIZE=10485760

# Enable heavy ML pipeline: EasyOCR, YOLOv8, Transformers.
# Requires ~4 GB RAM. Leave false on Render free tier.
ENABLE_HEAVY_ML=false


# -----------------------------------------------------------------------------
# REDIS  (optional)
# -----------------------------------------------------------------------------
# Uncomment if you add Redis-backed caching or rate limiting.
# REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# EMAIL / SMTP  (optional)
# -----------------------------------------------------------------------------
# Uncomment to enable email notifications.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
