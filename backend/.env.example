# ============================================
# PREPIQ BACKEND — ENVIRONMENT TEMPLATE
# ============================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env with real secrets — it is in .gitignore.

# ============================================
# REQUIRED — Database
# ============================================
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@YOUR_PROJECT.supabase.co:6543/postgres?pgbouncer=true

# ============================================
# REQUIRED — Supabase
# ============================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# ============================================
# REQUIRED — Security
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# REQUIRED — CORS
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# REQUIRED — AI / ML
# ============================================
GEMINI_API_KEY=your-gemini-api-key-here
BYTEZ_API_KEY=your-bytez-api-key-here

# ============================================
# OPTIONAL — Application
# ============================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
MAX_FILE_SIZE=10485760
UPLOAD_FOLDER=./uploads

# Enable heavy ML features (EasyOCR, YOLOv8, Transformers)
# WARNING: Requires significant RAM — only enable on paid tiers
# ENABLE_HEAVY_ML=false
